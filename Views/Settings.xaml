<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="IPAbuyer.Views.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IPAbuyer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="50,20,50,50" Spacing="16">
                <TextBlock x:Uid="/SettingPage/Title" Style="{ThemeResource TitleLargeTextBlockStyle}" />
                <TextBlock x:Uid="/SettingPage/About" Style="{ThemeResource SubtitleTextBlockStyle}" />

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="/SettingPage/About_Country_Code"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <Grid Grid.Column="1" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="CountryCodeTextBox"
                                    Grid.Column="0"
                                    MinHeight="36"
                                    KeyUp="CountryCodeTextBox_KeyUp"
                                    PlaceholderText="cn" />
                                <Button
                                    x:Uid="/SettingPage/About_Country_Code_Button"
                                    Grid.Column="1"
                                    MinHeight="36"
                                    Click="CountryCodeButton" />
                            </Grid>
                        </Grid>

                        <Grid ColumnSpacing="12" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="/SettingPage/About_Download_Directory"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <Grid Grid.Column="1" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="DownloadDirectoryTextBox"
                                    Grid.Column="0"
                                    MinHeight="36"
                                    PlaceholderText="C:\\Users\\username\\Downloads" />
                                <Button
                                    x:Uid="/SettingPage/About_Download_Directory_Button"
                                    Grid.Column="1"
                                    MinHeight="36"
                                    Click="SaveDownloadDirectoryButton_Click" />
                                <Button
                                    x:Uid="/SettingPage/About_Download_Directory_Default_Button"
                                    Grid.Column="2"
                                    MinHeight="36"
                                    Click="ResetDownloadDirectoryButton_Click" />
                            </Grid>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="/SettingPage/About_Developer"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <Button
                                x:Uid="/SettingPage/About_Developer_Button"
                                Grid.Column="1"
                                MinHeight="36"
                                HorizontalAlignment="Right"
                                Click="GithubButton" />
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="/SettingPage/About_Feedback_Email"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <Button
                                x:Uid="/SettingPage/About_Feedback_Email_Button"
                                Grid.Column="1"
                                MinHeight="36"
                                HorizontalAlignment="Right"
                                Click="CopyFeedbackEmailButton_Click" />
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="/SettingPage/About_Remove_Database"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <Button
                                x:Uid="/SettingPage/About_Remove_Database_Button"
                                Grid.Column="1"
                                MinHeight="36"
                                HorizontalAlignment="Right"
                                Background="Red"
                                Click="DeleteDataBase"
                                Foreground="White" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Uid="/QA/Title" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <MenuFlyoutSeparator />
                <TextBlock
                    x:Uid="/QA/Q1"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    TextWrapping="Wrap" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Uid="/QA/A1"
                        Grid.Column="0"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        TextWrapping="Wrap" />
                    <Button
                        x:Uid="/QA/Apple_Account_Button"
                        Grid.Row="1"
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="AppleAccountButton" />
                </Grid>
                <MenuFlyoutSeparator />
                <TextBlock
                    x:Uid="/QA/Q2"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Uid="/QA/A2"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    TextWrapping="Wrap" />
                <MenuFlyoutSeparator />
                <TextBlock
                    x:Uid="/QA/Q3"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Uid="/QA/A3"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    TextWrapping="Wrap" />
                <MenuFlyoutSeparator />
                <TextBlock
                    x:Uid="/QA/Q4"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Uid="/QA/A4"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    TextWrapping="Wrap" />
                <MenuFlyoutSeparator />
                <TextBlock
                    x:Uid="/QA/Q5"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Uid="/QA/A5"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    TextWrapping="Wrap" />
                <MenuFlyoutSeparator />
                <TextBlock
                    x:Uid="/QA/Q6"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Uid="/QA/A6"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    TextWrapping="Wrap" />
                <MenuFlyoutSeparator />
                <TextBlock
                    x:Uid="/QA/Q7"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Uid="/QA/A7"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
