<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="IPAbuyer.Views.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid
                MaxWidth="920"
                Margin="32,20,32,40"
                HorizontalAlignment="Center">
                <StackPanel Spacing="12">
                    <TextBlock
                        x:Uid="/SettingPage/Title"
                        Margin="0,0,0,8"
                        Style="{ThemeResource TitleLargeTextBlockStyle}" />

                    <Border
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock
                                x:Uid="/SettingPage/About_Country_Code"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <TextBox
                                x:Name="CountryCodeTextBox"
                                KeyUp="CountryCodeTextBox_KeyUp" />
                            <Button
                                x:Uid="/SettingPage/About_Country_Code_Button"
                                HorizontalAlignment="Left"
                                Click="CountryCodeButton" />
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <TextBlock
                                x:Uid="/SettingPage/About_Download_Directory"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <TextBox
                                x:Name="DownloadDirectoryTextBox"
                                IsReadOnly="True" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button
                                    x:Uid="/SettingPage/About_Download_Directory_Button"
                                    Grid.Column="0"
                                    Click="PickDownloadDirectoryButton_Click" />
                                <Button
                                    x:Uid="/SettingPage/About_Download_Directory_Default_Button"
                                    Grid.Column="1"
                                    Click="ResetDownloadDirectoryButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="/SettingPage/About_Developer"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <Button
                                x:Uid="/SettingPage/About_Developer_Button"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                Click="GithubButton" />
                        </Grid>
                    </Border>

                    <Border
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="/SettingPage/About_Feedback_Email"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="Wrap" />
                            <Button
                                x:Uid="/SettingPage/About_Feedback_Email_Button"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                Click="CopyFeedbackEmailButton_Click" />
                        </Grid>
                    </Border>

                    <Border
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Uid="/SettingPage/About_Remove_Database"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Style="{ThemeResource BodyTextBlockStyle}"
                                    TextWrapping="Wrap" />
                                <Button
                                    x:Uid="/SettingPage/About_Remove_Database_Button"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Background="Red"
                                    Click="DeleteDataBase"
                                    Foreground="White" />
                            </Grid>

                            <TextBlock
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="说明：仅清空本地已购买/已拥有记录，不会影响你的 Apple 账户购买历史。" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
