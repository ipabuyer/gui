<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="IPAbuyer.Views.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:IPAbuyer.Models"
    mc:Ignorable="d">
    <Grid Margin="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="7*" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,8,0,0" Orientation="Horizontal" Spacing="8">
                <Button
                    x:Name="StartQueueButton"
                    MinHeight="36"
                    Content="开始下载队列"
                    Click="StartQueueButton_Click" />
                <Button
                    x:Name="RemoveQueueButton"
                    MinHeight="36"
                    Content="移出下载队列"
                    Click="RemoveQueueButton_Click" />
                <Button
                    MinHeight="36"
                    Content="打开下载目录"
                    Click="OpenDirectoryButton_Click" />
                <Button
                    x:Name="CancelAllButton"
                    MinHeight="36"
                    Content="终止所有下载"
                    Click="CancelAllButton_Click" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Margin="0,12,0,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <ListView
                    x:Name="QueueListView"
                    SelectionMode="Multiple">
                    <ListView.Header>
                        <Grid Padding="8,0,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="DownloadNameHeaderText"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Tapped="SortHeader_Tapped"
                                Tag="name"
                                Text="App名称" />
                            <TextBlock
                                x:Name="DownloadIdHeaderText"
                                Grid.Column="2"
                                HorizontalAlignment="Center"
                                Tapped="SortHeader_Tapped"
                                Tag="appid"
                                Text="AppID" />
                            <TextBlock
                                x:Name="DownloadDeveloperHeaderText"
                                Grid.Column="3"
                                HorizontalAlignment="Center"
                                Tapped="SortHeader_Tapped"
                                Tag="developer"
                                Text="开发者" />
                            <TextBlock
                                x:Name="DownloadVersionHeaderText"
                                Grid.Column="4"
                                HorizontalAlignment="Center"
                                Tapped="SortHeader_Tapped"
                                Tag="version"
                                Text="版本号" />
                            <TextBlock
                                x:Name="DownloadPriceHeaderText"
                                Grid.Column="5"
                                HorizontalAlignment="Center"
                                Tapped="SortHeader_Tapped"
                                Tag="price"
                                Text="价格" />
                            <TextBlock
                                x:Name="DownloadStatusHeaderText"
                                Grid.Column="6"
                                HorizontalAlignment="Center"
                                Tapped="SortHeader_Tapped"
                                Tag="status"
                                Text="下载状态" />
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DownloadQueueItem">
                            <Grid Padding="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Width="24"
                                    Height="24"
                                    CornerRadius="6"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <Image
                                        Width="24"
                                        Height="24"
                                        Source="{x:Bind ArtworkUrl}"
                                        Stretch="UniformToFill" />
                                </Border>

                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind Name}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind AppId}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="3"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind Developer}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="4"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind Version}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="5"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind Price}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="6"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind StatusText}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="日志" />
                    <Button
                        MinHeight="36"
                        Content="复制"
                        Click="CopyLogButton_Click" />
                    <Button
                        MinHeight="36"
                        Content="清空"
                        Click="ClearLogButton_Click" />
                    <Button
                        MinHeight="36"
                        Content="终止当前app下载"
                        Click="CancelCurrentButton_Click" />
                </StackPanel>

                <TextBox
                    x:Name="LogTextBox"
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>
    </Grid>
</Page>
