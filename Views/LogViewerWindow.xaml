<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IPAbuyer.Views.LogViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        x:Name="LogViewerRoot"
        Padding="16"
        Background="Transparent">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="12"
                Background="#121212"
                BorderBrush="#2A2A2A"
                BorderThickness="1"
                CornerRadius="8">
                <ScrollViewer
                    x:Name="LogScrollViewer"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <RichTextBlock
                        x:Name="LogViewer"
                        FontFamily="Cascadia Mono, Consolas"
                        FontSize="13"
                        IsTextSelectionEnabled="True"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>

            <StackPanel
                Grid.Row="1"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="CopyButton"
                    Width="132"
                    MinHeight="32"
                    Padding="12,0,12,0"
                    Click="CopyButton_Click" />
                <Button
                    x:Name="ClearButton"
                    Width="132"
                    MinHeight="32"
                    Padding="12,0,12,0"
                    Click="ClearButton_Click" />
                <Button
                    x:Name="CloseButton"
                    Width="132"
                    MinHeight="32"
                    Padding="12,0,12,0"
                    Click="CloseButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
