<Window
  x:Class="IPAbuyer.Views.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="using:IPAbuyer"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <!-- 自定义标题栏 -->
    <Grid x:Name="CustomTitleBar" Grid.Row="0" Background="{ThemeResource SystemBaseLowColor}"
      Height="48">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="48" /> <!-- 侧边栏展开按钮 -->
        <ColumnDefinition Width="48" /> <!-- logo -->
        <ColumnDefinition Width="2*" /> <!-- 标题 -->
        <ColumnDefinition Width="3*" /> <!-- 搜索框 -->
      </Grid.ColumnDefinitions>
      <!-- 侧边栏展开按钮 -->
      <Button x:Name="PaneToggleButton" Grid.Column="0" Width="40" Height="40" Margin="4,4,4,4"
        Click="PaneToggleButton_Click">
        <FontIcon Glyph="&#xE700;" FontFamily="Segoe MDL2 Assets" />
      </Button>
      <!-- logo -->
      <Image Grid.Column="1" Width="32" Height="32" VerticalAlignment="Center"
        Source="/Assets/Icon.ico" />
      <!-- 标题 -->
      <TextBlock Grid.Column="2" Text="IPAbuyer - 快速购买 AppStore 中的应用" VerticalAlignment="Center"
        FontSize="18" FontWeight="SemiBold" />
      <!-- 搜索框 -->
      <Grid Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="260" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="AppNameBox" Width="240" Height="32" PlaceholderText="请输入App名称"
          Margin="0,0,8,0" VerticalAlignment="Center" />
        <Button x:Name="SearchButton" Grid.Column="1" Content="搜索" Width="60" Height="32"
          Click="SearchButton_Click" />
      </Grid>
    </Grid>
    <!-- 主内容区域 -->
    <NavigationView x:Name="NavView"
      Grid.Row="1"
      PaneDisplayMode="Left"
      IsSettingsVisible="False"
      ItemInvoked="NavView_ItemInvoked"
      IsPaneToggleButtonVisible="False"
      IsBackButtonVisible="Collapsed"
      OpenPaneLength="180">
      <NavigationView.MenuItems>
        <NavigationViewItem Content="主页"
          Icon="Home"
          Tag="MainPage" />
        <NavigationViewItem Content="登录"
          Icon="Contact"
          Tag="LoginPage" />
        <NavigationViewItem Content="设置"
          Icon="Setting"
          Tag="SettingsPage" />
      </NavigationView.MenuItems>
      <Frame x:Name="ContentFrame" />
    </NavigationView>
  </Grid>
</Window>