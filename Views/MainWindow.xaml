<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IPAbuyer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IPAbuyer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.Resources>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewMinimalPaneBackground" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
            <SolidColorBrush x:Key="TitleBarBackground" Color="Transparent" />
            <SolidColorBrush x:Key="TitleBarInactiveBackground" Color="Transparent" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Grid.Row="0"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.LeftHeader>
                <StackPanel
                    Margin="12,0,16,0"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <Image
                        Width="20"
                        Height="20"
                        Source="ms-appx:///Assets/Square44x44Logo.scale-200.png" />
                    <TextBlock
                        x:Uid="MainWindow/TitleBar/TitleText"
                        x:Name="TitleBarTextBlock"
                        VerticalAlignment="Center" />
                </StackPanel>
            </TitleBar.LeftHeader>
            <TitleBar.Content>
                <Grid x:Name="SearchBoxHost">
                    <AutoSuggestBox
                        x:Uid="MainWindow/SearchBox"
                        x:Name="AppNameBox"
                        Width="360"
                        MinWidth="220"
                        MaxWidth="420"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        QueryIcon="Find"
                        QuerySubmitted="AppNameBox_QuerySubmitted" />
                </Grid>
            </TitleBar.Content>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            ItemInvoked="NavView_ItemInvoked"
            OpenPaneLength="224"
            CompactPaneLength="56"
            IsPaneOpen="True"
            PaneDisplayMode="Left"
            Background="Transparent">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="MainWindow/Nav/Main" Icon="Home" Tag="MainPage" />
                <NavigationViewItem x:Uid="MainWindow/Nav/Account" Icon="Contact" Tag="LoginPage" />
                <NavigationViewItem x:Uid="MainWindow/Nav/Settings" Icon="Setting" Tag="SettingsPage" />
            </NavigationView.MenuItems>
            <Grid Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                <Frame x:Name="ContentFrame" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>

