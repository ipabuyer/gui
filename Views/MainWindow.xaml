<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IPAbuyer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IPAbuyer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Grid.Row="0"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.LeftHeader>
                <TextBlock
                    x:Uid="MainWindow/TitleBar/TitleText"
                    x:Name="TitleBarTextBlock"
                    Margin="12,0,16,0"
                    VerticalAlignment="Center"
                    Style="{ThemeResource BodyStrongTextBlockStyle}" />
            </TitleBar.LeftHeader>
            <TitleBar.Content>
                <AutoSuggestBox
                    x:Uid="MainWindow/SearchBox"
                    x:Name="AppNameBox"
                    Width="450"
                    MinWidth="240"
                    MaxWidth="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    QueryIcon="Find"
                    QuerySubmitted="AppNameBox_QuerySubmitted" />
            </TitleBar.Content>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            ItemInvoked="NavView_ItemInvoked"
            OpenPaneLength="224"
            CompactPaneLength="56"
            IsPaneOpen="True"
            PaneDisplayMode="Left"
            Background="Transparent">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="MainWindow/Nav/Main" Icon="Home" Tag="MainPage" />
                <NavigationViewItem x:Uid="MainWindow/Nav/Account" Icon="Contact" Tag="LoginPage" />
                <NavigationViewItem x:Uid="MainWindow/Nav/Settings" Icon="Setting" Tag="SettingsPage" />
            </NavigationView.MenuItems>
            <Grid>
                <Frame x:Name="ContentFrame" />
                <ProgressBar
                    x:Name="SearchLoadingBar"
                    Height="2"
                    VerticalAlignment="Top"
                    IsIndeterminate="True"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"
                    Canvas.ZIndex="10" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>

