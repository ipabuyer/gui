<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IPAbuyer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IPAbuyer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="CustomTitleBar"
            Grid.Row="0"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="PaneToggleButton"
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    Click="PaneToggleButton_Click">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE700;" />
                </Button>
                <TextBlock
                    x:Uid="MainWindow/TitleBar/TitleText"
                    x:Name="TitleBarTextBlock"
                    Grid.Column="2"
                    Margin="10"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"/>
                <Grid Grid.Column="3" Width="300" MinWidth="200" MaxWidth="300" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <AutoSuggestBox
                        x:Uid="MainWindow/SearchBox"
                        x:Name="AppNameBox"
                        QueryIcon="Find"
                        QuerySubmitted="AppNameBox_QuerySubmitted" />
                </Grid>
            </Grid>
        </Border>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            ItemInvoked="NavView_ItemInvoked"
            OpenPaneLength="224"
            CompactPaneLength="56"
            PaneDisplayMode="LeftCompact"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
            <NavigationView.PaneHeader>
                <Border Margin="12,12,12,8">
                    <TextBlock Text="导航" Style="{ThemeResource BodyStrongTextBlockStyle}" Opacity="0.78" />
                </Border>
            </NavigationView.PaneHeader>
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="MainWindow/Nav/Main" Icon="Home" Tag="MainPage" />
                <NavigationViewItem x:Uid="MainWindow/Nav/Account" Icon="Contact" Tag="LoginPage" />
                <NavigationViewItem x:Uid="MainWindow/Nav/Downloads" Icon="Download" Tag="DownloadsPage" />
                <NavigationViewItem x:Uid="MainWindow/Nav/Settings" Icon="Setting" Tag="SettingsPage" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <ProgressBar
            x:Name="SearchLoadingBar"
            Grid.Row="1"
            Height="2"
            VerticalAlignment="Top"
            IsIndeterminate="True"
            IsHitTestVisible="False"
            Visibility="Collapsed"
            Canvas.ZIndex="10" />
    </Grid>
</Window>

