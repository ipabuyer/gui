<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="IPAbuyer.Views.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="using:IPAbuyer" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="48" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid x:Name="CustomTitleBar" Grid.Row="0" Height="48" Background="{ThemeResource SystemBaseLowColor}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="48" />
        <ColumnDefinition Width="48" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Button x:Name="PaneToggleButton" Grid.Column="0" Width="40" Height="40" Margin="4" Click="PaneToggleButton_Click">
        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE700;" />
      </Button>
      <Image Grid.Column="1" Width="32" Height="32" VerticalAlignment="Center" Source="/Assets/StoreLogo.png" />
      <Grid Grid.Column="2" Margin="12,0,12,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Uid="MainWindow/TitleBar/TitleText" x:Name="TitleBarTextBlock" Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
        <Grid Grid.Column="1" Width="420" MinWidth="220" MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center">
          <AutoSuggestBox x:Uid="MainWindow/SearchBox" x:Name="AppNameBox" QueryIcon="Find" QuerySubmitted="AppNameBox_QuerySubmitted" />
        </Grid>
      </Grid>
      <ProgressBar x:Name="SearchLoadingBar" Grid.ColumnSpan="3" Height="2" VerticalAlignment="Bottom" IsIndeterminate="True" IsHitTestVisible="False" Visibility="Collapsed" />
    </Grid>
    <NavigationView x:Name="NavView" Grid.Row="1" IsBackButtonVisible="Collapsed" IsPaneToggleButtonVisible="False" IsSettingsVisible="False" ItemInvoked="NavView_ItemInvoked" OpenPaneLength="180" PaneDisplayMode="Left">
      <NavigationView.MenuItems>
        <NavigationViewItem x:Uid="MainWindow/Nav/Main" Icon="Home" Tag="MainPage" />
        <NavigationViewItem x:Uid="MainWindow/Nav/Account" Icon="Contact" Tag="LoginPage" />
        <NavigationViewItem x:Uid="MainWindow/Nav/Downloads" Icon="Download" Tag="DownloadsPage" />
        <NavigationViewItem x:Uid="MainWindow/Nav/Settings" Icon="Setting" Tag="SettingsPage" />
      </NavigationView.MenuItems>
      <Frame x:Name="ContentFrame" />
    </NavigationView>
  </Grid>
</Window>
