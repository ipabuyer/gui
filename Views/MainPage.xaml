<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="IPAbuyer.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:IPAbuyer.Models"
    mc:Ignorable="d">
    <Page.Content>
        <Grid Margin="24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="7*" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Name="BatchPurchaseButton"
                        Grid.Column="0"
                        MinHeight="36"
                        Content="购买"
                        Click="BatchPurchaseButton_Click" />
                    <Button
                        x:Name="AddToDownloadQueueButton"
                        Grid.Column="1"
                        MinHeight="36"
                        Content="添加到下载队列"
                        Click="AddToDownloadQueueButton_Click" />
                    <ComboBox
                        x:Name="ScreeningComboBox"
                        Grid.Column="2"
                        MinHeight="36"
                        SelectedIndex="0"
                        SelectionChanged="ScreeningComboBox_SelectionChanged">
                        <ComboBoxItem x:Name="All" Tag="All">全部</ComboBoxItem>
                        <ComboBoxItem x:Name="OnlyNotPurchased" Tag="OnlyNotPurchased">仅未购买</ComboBoxItem>
                        <ComboBoxItem x:Name="OnlyPurchased" Tag="OnlyPurchased">仅已购买</ComboBoxItem>
                        <ComboBoxItem x:Name="OnlyHad" Tag="OnlyHad">仅已拥有</ComboBoxItem>
                    </ComboBox>
                </Grid>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ProgressBar
                            x:Name="PurchaseLoadingBar"
                            Grid.Row="0"
                            Height="3"
                            IsIndeterminate="True"
                            IsHitTestVisible="False"
                            Visibility="Collapsed" />

                        <Grid Grid.Row="1" Padding="12,6,12,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                x:Name="NameHeaderText"
                                Grid.Column="1"
                                Background="Transparent"
                                BorderThickness="0"
                                MinHeight="24"
                                Padding="0"
                                HorizontalAlignment="Center"
                                Click="SortHeader_Click"
                                Tag="name"
                                Content="App名称" />
                            <Button
                                x:Name="IdHeaderText"
                                Grid.Column="2"
                                Background="Transparent"
                                BorderThickness="0"
                                MinHeight="24"
                                Padding="0"
                                HorizontalAlignment="Center"
                                Click="SortHeader_Click"
                                Tag="id"
                                Content="AppID" />
                            <Button
                                x:Name="DeveloperHeaderText"
                                Grid.Column="3"
                                Background="Transparent"
                                BorderThickness="0"
                                MinHeight="24"
                                Padding="0"
                                HorizontalAlignment="Center"
                                Click="SortHeader_Click"
                                Tag="developer"
                                Content="开发者" />
                            <Button
                                x:Name="VersionHeaderText"
                                Grid.Column="4"
                                Background="Transparent"
                                BorderThickness="0"
                                MinHeight="24"
                                Padding="0"
                                HorizontalAlignment="Center"
                                Click="SortHeader_Click"
                                Tag="version"
                                Content="版本号" />
                            <Button
                                x:Name="PriceHeaderText"
                                Grid.Column="5"
                                Background="Transparent"
                                BorderThickness="0"
                                MinHeight="24"
                                Padding="0"
                                HorizontalAlignment="Center"
                                Click="SortHeader_Click"
                                Tag="price"
                                Content="价格" />
                            <Button
                                x:Name="PurchasedHeaderText"
                                Grid.Column="6"
                                Background="Transparent"
                                BorderThickness="0"
                                MinHeight="24"
                                Padding="0"
                                HorizontalAlignment="Center"
                                Click="SortHeader_Click"
                                Tag="purchased"
                                Content="购买状态" />
                        </Grid>

                        <ListView
                            x:Name="ResultList"
                            Grid.Row="2"
                            Margin="0,0,0,10"
                            ContainerContentChanging="ResultList_ContainerContentChanging"
                            IsMultiSelectCheckBoxEnabled="True"
                            SelectionMode="Multiple">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:SearchResult">
                                    <Grid Margin="-40,0,0,0" Padding="52,10,12,10">
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="购买" Click="ContextMenuPurchase_Click" />
                                                <MenuFlyoutItem Text="加入下载队列" Click="ContextMenuAddToQueue_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="标记为未购买" Click="ContextMenuMarkNotPurchased_Click" />
                                                <MenuFlyoutItem Text="标记为已购买" Click="ContextMenuMarkPurchased_Click" />
                                                <MenuFlyoutItem Text="标记为已拥有" Click="ContextMenuMarkOwned_Click" />
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="复制App名称" Click="ContextMenuCopyName_Click" />
                                                <MenuFlyoutItem Text="复制ID" Click="ContextMenuCopyId_Click" />
                                                <MenuFlyoutItem Text="复制版本号" Click="ContextMenuCopyVersion_Click" />
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                            <Border
                                                Width="24"
                                                Height="24"
                                                CornerRadius="6"
                                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="0.6">
                                                <Image
                                                    Width="24"
                                                    Height="24"
                                                    Source="{x:Bind artworkUrl}"
                                                    Stretch="UniformToFill" />
                                            </Border>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Text="{x:Bind name}"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTipService.ToolTip="{x:Bind name}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" HorizontalAlignment="Center" Text="{x:Bind id}" />
                                        <TextBlock
                                            Grid.Column="3"
                                            HorizontalAlignment="Center"
                                            Text="{x:Bind developer}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{x:Bind developer}" />
                                        <TextBlock Grid.Column="4" HorizontalAlignment="Center" Text="{x:Bind version}" />
                                        <TextBlock
                                            x:Name="PriceTextBlock"
                                            Grid.Column="5"
                                            HorizontalAlignment="Center"
                                            Text="{x:Bind price}" />
                                        <TextBlock
                                            x:Name="PurchasedTextBlock"
                                            Grid.Column="6"
                                            HorizontalAlignment="Center"
                                            Text="{x:Bind purchased}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <Border
                Grid.Row="1"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Text="日志" />
                        <Button
                            MinHeight="32"
                            Content="复制"
                            Click="CopyHomeLog_Click" />
                        <Button
                            MinHeight="32"
                            Content="清空"
                            Click="ClearHomeLog_Click" />
                    </StackPanel>

                    <ScrollViewer
                        x:Name="HomeLogScrollViewer"
                        Grid.Row="1"
                        Margin="0,8,0,0"
                        VerticalScrollBarVisibility="Auto">
                        <RichTextBlock
                            x:Name="HomeLogTextBlock"
                            IsTextSelectionEnabled="True"
                            TextWrapping="WrapWholeWords" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Page.Content>
</Page>
