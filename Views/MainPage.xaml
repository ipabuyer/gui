<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="IPAbuyer.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IPAbuyer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:IPAbuyer.Models"
    mc:Ignorable="d">
    <Page.Content>
        <Grid Margin="50,20,50,20">
            <!--  操作按钮区  -->
            <Grid
                Margin="0,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="BatchPurchaseButton"
                    x:Uid="/MainPage/Purchase_Button"
                    Grid.Column="0"
                    Margin="0,0,0,0"
                    Click="BatchPurchaseButton_Click" />
                <!-- <Button Grid.Column="1"
                    Margin="10,0,0,0"
                    x:Name="BatchDownloadButton"
                    Click="BatchDownloadButton_Click"
                    x:Uid="/MainPage/Download_Button" />-->
                <ComboBox
                    x:Name="ScreeningComboBox"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    SelectedIndex="0"
                    SelectionChanged="ScreeningComboBox_SelectionChanged">
                    <ComboBoxItem x:Name="All" Tag="All">筛选</ComboBoxItem>
                    <ComboBoxItem x:Name="OnlyNotPurchased" Tag="OnlyNotPurchased">仅未购买</ComboBoxItem>
                    <ComboBoxItem x:Name="OnlyPurchased" Tag="OnlyPurchased">仅已购买</ComboBoxItem>
                    <ComboBoxItem x:Name="OnlyHad" Tag="OnlyHad">仅已拥有</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!--  表格区  -->
            <Border
                Margin="0,50,0,10"
                Background="#80F0F8FF"
                BorderBrush="White"
                BorderThickness="1"
                CornerRadius="2">
                <ListView
                    x:Name="ResultList"
                    Margin="0,10,0,10"
                    SelectionMode="Multiple">
                    <ListView.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                Text="App名称" />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Text="AppID" />
                            <TextBlock
                                Grid.Column="2"
                                HorizontalAlignment="Center"
                                Text="包名" />
                            <TextBlock
                                Grid.Column="3"
                                HorizontalAlignment="Center"
                                Text="版本" />
                            <TextBlock
                                Grid.Column="4"
                                HorizontalAlignment="Center"
                                Text="价格" />
                            <TextBlock
                                Grid.Column="5"
                                HorizontalAlignment="Center"
                                Text="状态" />
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SearchResult">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="Left"
                                    Text="{x:Bind name}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind name}" />
                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind id}" />
                                <TextBlock
                                    Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind bundleID}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind bundleID}" />
                                <TextBlock
                                    Grid.Column="3"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind version}" />
                                <TextBlock
                                    Grid.Column="4"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind price}" />
                                <TextBlock
                                    Grid.Column="5"
                                    HorizontalAlignment="Center"
                                    Text="{x:Bind purchased}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

        </Grid>
    </Page.Content>
</Page>
