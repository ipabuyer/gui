<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="IPAbuyer.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IPAbuyer.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:IPAbuyer.Models"
    mc:Ignorable="d">
    <Page.Resources>
        <CornerRadius x:Key="MainUnifiedCornerRadius">8</CornerRadius>
        <local:MainPageFreePriceVisibilityConverter x:Key="MainPageFreePriceVisibilityConverter" />
        <local:MainPageNonFreePriceVisibilityConverter x:Key="MainPageNonFreePriceVisibilityConverter" />
        <local:MainPagePurchasedForegroundConverter x:Key="MainPagePurchasedForegroundConverter" />
        <local:MainPageImageUriConverter x:Key="MainPageImageUriConverter" />
        <local:MainPageAppActionTextConverter x:Key="MainPageAppActionTextConverter" />
        <local:MainPageAppActionEnabledConverter x:Key="MainPageAppActionEnabledConverter" />
        <Style x:Key="MainResultListViewItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Page.Resources>
    <Page.Background>Transparent</Page.Background>
    <Page.Content>
        <Grid Padding="{StaticResource AppPagePadding}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <Button x:Uid="MainPage/Action/OpenLogButton" x:Name="OpenLogButton" Click="ShowHomeLogDialog_Click" />
                        <ComboBox x:Name="ScreeningComboBox" MinWidth="120" SelectedIndex="0" SelectionChanged="ScreeningComboBox_SelectionChanged">
                            <ComboBoxItem x:Uid="MainPage/Filter/AllItem" x:Name="All" Tag="All" />
                            <ComboBoxItem x:Uid="MainPage/Filter/OnlyNotPurchasedItem" x:Name="OnlyNotPurchased" Tag="OnlyNotPurchased" />
                            <ComboBoxItem x:Uid="MainPage/Filter/OnlyPurchasedItem" x:Name="OnlyPurchased" Tag="OnlyPurchased" />
                            <ComboBoxItem x:Uid="MainPage/Filter/OnlyOwnedItem" x:Name="OnlyHad" Tag="OnlyHad" />
                        </ComboBox>
                    </StackPanel>
                    <Button Grid.Column="1" x:Uid="MainPage/Action/CancelAllDownloadsButton" x:Name="CancelAllDownloadsButton" Click="CancelAllDownloadsButton_Click" Visibility="Collapsed" />
                </Grid>

                <Grid Grid.Row="1">
                    <ListView
                        x:Name="ResultList"
                        Background="Transparent"
                        IsItemClickEnabled="False"
                        ItemContainerStyle="{StaticResource MainResultListViewItemStyle}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:SearchResult">
                                <controls:SettingsCard
                                    HorizontalAlignment="Stretch"
                                    Description="{x:Bind developer, Mode=OneWay}"
                                    Header="{x:Bind name, Mode=OneWay}">
                                    <controls:SettingsCard.HeaderIcon>
                                        <BitmapIcon
                                            Width="48"
                                            Height="48"
                                            ShowAsMonochrome="False"
                                            UriSource="{Binding artworkUrl, Converter={StaticResource MainPageImageUriConverter}}" />
                                    </controls:SettingsCard.HeaderIcon>
                                    <Grid ColumnSpacing="18" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind version, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{x:Bind version, Mode=OneWay}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Foreground="{Binding purchased, Converter={StaticResource MainPagePurchasedForegroundConverter}}"
                                            Text="{x:Bind purchased, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{x:Bind purchased, Mode=OneWay}" />
                                        <Button
                                            Grid.Column="2"
                                            MinWidth="96"
                                            Click="AppActionButton_Click"
                                            Content="{Binding purchased, Converter={StaticResource MainPageAppActionTextConverter}}"
                                            IsEnabled="{Binding purchased, Converter={StaticResource MainPageAppActionEnabledConverter}}" />
                                        <Button
                                            Grid.Column="3"
                                            Width="36"
                                            Height="36"
                                            Padding="0"
                                            HorizontalAlignment="Right">
                                            <Button.Content>
                                                <FontIcon FontSize="16" Glyph="&#xE712;" />
                                            </Button.Content>
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem x:Uid="MainPage/Context/MarkNotPurchasedItem" Click="ContextMenuMarkNotPurchased_Click" />
                                                    <MenuFlyoutItem x:Uid="MainPage/Context/MarkPurchasedItem" Click="ContextMenuMarkPurchased_Click" />
                                                    <MenuFlyoutItem x:Uid="MainPage/Context/MarkOwnedItem" Click="ContextMenuMarkOwned_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem x:Uid="MainPage/Context/CopyNameItem" Click="ContextMenuCopyName_Click" />
                                                    <MenuFlyoutItem x:Uid="MainPage/Context/CopyVersionItem" Click="ContextMenuCopyVersion_Click" />
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Grid>
                                </controls:SettingsCard>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <ProgressRing
                        x:Name="TableLoadingRing"
                        Width="44"
                        Height="44"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Canvas.ZIndex="10"
                        IsActive="False"
                        IsHitTestVisible="False"
                        Visibility="Collapsed" />
                </Grid>

                <InfoBar x:Name="HomeStatusInfoBar" Grid.Row="2" IsOpen="False" IsClosable="True" Severity="Informational" />
            </Grid>
        </Grid>
    </Page.Content>
</Page>
