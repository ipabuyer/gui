<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="IPAbuyer.Views.LoginPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Page.Background>Transparent</Page.Background>
  <Grid Padding="{StaticResource AppPagePadding}" RowSpacing="12">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <Grid>
        <StackPanel Spacing="16">
          <StackPanel Margin="0,0,0,4" Spacing="6">
            <TextBlock x:Uid="LoginPage/TitleText" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock x:Uid="LoginPage/SubtitleText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{ThemeResource BodyTextBlockStyle}" />
          </StackPanel>
          <TextBlock x:Uid="LoginPage/PassphraseChangeHintText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
          <TextBlock x:Uid="LoginPage/NewAccountHintText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
          <Grid>
            <Border Padding="20" Style="{StaticResource AppSurfaceBorderStyle}">
              <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="130" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Uid="LoginPage/EmailLabel" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                <TextBox x:Uid="LoginPage/EmailInput" x:Name="EmailComboBox" Grid.Row="0" Grid.Column="1" Width="300" MinHeight="36" InputScope="EmailSmtpAddress" IsSpellCheckEnabled="False" KeyUp="Input_KeyUp" />
                <TextBlock x:Uid="LoginPage/PasswordLabel" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                <PasswordBox x:Uid="LoginPage/PasswordInput" x:Name="PasswordBox" Grid.Row="1" Grid.Column="1" Width="300" MinHeight="36" KeyUp="Input_KeyUp" PasswordRevealMode="Peek" />
                <TextBlock x:Uid="LoginPage/TwoFactorCodeLabel" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                <StackPanel x:Name="AuthCodeInlinePanel" Grid.Row="2" Grid.Column="1" Spacing="6" VerticalAlignment="Center" Visibility="Visible">
                  <PasswordBox x:Uid="LoginPage/TwoFactorCodeInput" x:Name="CodeBox" Width="300" MinHeight="36" KeyUp="CodeBox_KeyUp" PasswordRevealMode="Peek" />
                </StackPanel>
                <TextBlock x:Uid="LoginPage/PassphraseLabel" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" />
                <TextBox x:Uid="LoginPage/PassphraseInput" x:Name="PassphraseBox" Grid.Row="3" Grid.Column="1" Width="300" MinHeight="36" KeyUp="Input_KeyUp" />
              </Grid>
            </Border>
            <Border x:Name="OperationLockOverlay" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="{StaticResource AppControlCornerRadius}" Visibility="Collapsed">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <FontIcon FontSize="24" Glyph="&#xE72E;" />
                <TextBlock x:Uid="LoginPage/LockedOverlayText" />
              </StackPanel>
            </Border>
          </Grid>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Uid="LoginPage/LoginButton" x:Name="NextButton" MinWidth="150" MinHeight="36" HorizontalAlignment="Left" Click="NextButton_Click" Style="{StaticResource AccentButtonStyle}" />
            <Button x:Uid="LoginPage/QueryAuthInfoButton" x:Name="AuthInfoButton" MinWidth="150" MinHeight="36" HorizontalAlignment="Left" Click="AuthInfoButton_Click" />
            <Button x:Uid="LoginPage/LogoutButton" x:Name="LogoutButton" MinWidth="150" MinHeight="36" HorizontalAlignment="Left" Click="LogoutButton_Click" Style="{StaticResource AppDangerButtonStyle}" />
            <Button x:Uid="Common/AppleAccount/OpenButton" x:Name="OpenAppleAccountButton" MinWidth="150" MinHeight="36" HorizontalAlignment="Left" Click="OpenAppleAccountButton_Click" />
            <Button x:Uid="LoginPage/Action/OpenLogDialogButton" x:Name="OpenLoginLogButton" MinWidth="120" MinHeight="36" HorizontalAlignment="Left" Click="ShowLoginLogDialog_Click" />
          </StackPanel>
          <TextBlock x:Uid="LoginPage/TwoFactorHelpText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>
