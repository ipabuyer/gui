<Page
    x:Class="IPAbuyer.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="7*" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <StackPanel Spacing="12">
                    <StackPanel Margin="0,0,0,4" Spacing="4">
                        <TextBlock FontSize="38" FontWeight="SemiBold" Text="账户登录" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            Text="输入 Apple ID、密码和加密密钥，完成登录后即可购买与下载。" />
                    </StackPanel>
                    <TextBlock
                        Foreground="Gray"
                        Text="如需修改加密密钥，请先退出登录并重新登录。"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="Gray"
                        Text="提示：新创建的 Apple 账号需先在苹果设备 App Store 完成一次购买后，才能正常购买与下载。"
                        TextWrapping="WrapWholeWords" />

                    <Grid>
                        <Border
                            Padding="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Text="电子邮箱地址" />
                                <TextBox
                                    x:Name="EmailComboBox"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    MinWidth="360"
                                    MinHeight="36"
                                    InputScope="EmailSmtpAddress"
                                    IsSpellCheckEnabled="False"
                                    KeyUp="Input_KeyUp"
                                    PlaceholderText="example@icloud.com" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Text="密码" />
                                <PasswordBox
                                    x:Name="PasswordBox"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    MinWidth="360"
                                    MinHeight="36"
                                    KeyUp="Input_KeyUp"
                                    PasswordRevealMode="Peek"
                                    PlaceholderText="请输入密码" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="双重验证码" />
                            <StackPanel
                                x:Name="AuthCodeInlinePanel"
                                Grid.Row="2"
                                Grid.Column="1"
                                Spacing="6"
                                VerticalAlignment="Center"
                                Visibility="Visible">
                                    <PasswordBox
                                        x:Name="CodeBox"
                                        MinWidth="260"
                                        MinHeight="36"
                                        KeyUp="CodeBox_KeyUp"
                                        PasswordRevealMode="Peek"
                                        PlaceholderText="请输入双重验证码" />
                                </StackPanel>

                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Text="加密密钥" />
                                <TextBox
                                    x:Name="PassphraseBox"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    MinWidth="360"
                                    MinHeight="36"
                                    KeyUp="Input_KeyUp"
                                    PlaceholderText="用于 ipatool keychain-passphrase" />
                            </Grid>
                        </Border>

                        <Border
                            x:Name="OperationLockOverlay"
                            Background="#66D9D9D9"
                            CornerRadius="8"
                            Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                                <FontIcon FontSize="24" Glyph="&#xE72E;" />
                                <TextBlock Text="当前为已登录状态，操作区已锁定" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Name="NextButton"
                            MinWidth="150"
                            MinHeight="36"
                            HorizontalAlignment="Left"
                            Click="NextButton_Click"
                            Content="登录" />
                        <Button
                            x:Name="AuthInfoButton"
                            MinWidth="150"
                            MinHeight="36"
                            HorizontalAlignment="Left"
                            Click="AuthInfoButton_Click"
                            Content="查询登录状态" />
                        <Button
                            x:Name="LogoutButton"
                            MinWidth="150"
                            MinHeight="36"
                            HorizontalAlignment="Left"
                            Click="LogoutButton_Click"
                            Content="退出登录" />
                        <Button
                            x:Name="OpenAppleAccountButton"
                            MinWidth="150"
                            MinHeight="36"
                            HorizontalAlignment="Left"
                            Click="OpenAppleAccountButton_Click"
                            Content="打开苹果账户官网" />
                    </StackPanel>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="收不到验证码时，请点击“打开苹果账户官网”前往 account.apple.com 获取验证码。"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border
            Grid.Row="1"
            Padding="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                        Text="日志" />
                    <Button
                        MinHeight="32"
                        Content="复制"
                        Click="CopyLoginLog_Click" />
                    <Button
                        MinHeight="32"
                        Content="清空"
                        Click="ClearLoginLog_Click" />
                </StackPanel>

                <TextBox
                    x:Name="LoginLogOutput"
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>
    </Grid>
</Page>
