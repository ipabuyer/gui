<Page
    x:Class="IPAbuyer.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="100,20,100,20">
        <Grid VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Margin="0"
                VerticalAlignment="Top"
                FontSize="40"
                FontWeight="Bold">
                登录
            </TextBlock>
            <Button
                Grid.Column="1"
                MinWidth="120"
                Margin="0,0,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Click="BackToMainpage"
                FontSize="14">
                返回首页
            </Button>
        </Grid>
        <TextBlock
            Grid.Column="0"
            Margin="0,100,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            FontSize="16">
            输入您的Apple ID与密码以登录
        </TextBlock>
        <TextBlock
            Margin="0,128,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="Gray"
            Text="如需修改加密密钥，请先退出登录后重新登录并输入新的密钥。"
            TextWrapping="WrapWholeWords" />
        <TextBlock
            Margin="0,152,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="Gray"
            Text="提示：新创建的 Apple 账号需先在苹果设备登录 App Store 并完成一次购买后，才能正常购买/下载。"
            TextWrapping="WrapWholeWords" />
        <Grid
            Height="320"
            Margin="40,150,40,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,10,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                电子邮件地址
            </TextBlock>
            <TextBox
                x:Name="EmailComboBox"
                Grid.Row="0"
                Grid.Column="1"
                MinWidth="300"
                MinHeight="30"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                InputScope="EmailSmtpAddress"
                IsSpellCheckEnabled="False"
                KeyUp="Input_KeyUp"
                PlaceholderText="example@icloud.com" />

            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,0,10,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                密码
            </TextBlock>
            <PasswordBox
                x:Name="PasswordBox"
                Grid.Row="1"
                Grid.Column="1"
                MinWidth="300"
                MinHeight="30"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                KeyUp="Input_KeyUp"
                PlaceholderText="请输入密码" />

            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Margin="0,0,10,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                加密密钥
            </TextBlock>
            <PasswordBox
                x:Name="PassphraseBox"
                Grid.Row="2"
                Grid.Column="1"
                MinWidth="300"
                MinHeight="30"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                KeyUp="Input_KeyUp"
                PlaceholderText="用于 ipatool keychain-passphrase" />
        </Grid>

        <Button
            x:Name="NextButton"
            MinWidth="120"
            Margin="0,140,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="NextButton_Click"
            Content="登录" />

        <TextBlock
            x:Name="ResultText"
            Margin="0,0,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Foreground="Gray"
            TextWrapping="Wrap" />

        <!--  警告弹窗  -->
        <ContentDialog
            x:Name="WarningDialog"
            Title="警告"
            CloseButtonText="确认"
            DefaultButton="Primary" />

        <!--  验证码弹窗  -->
        <ContentDialog
            x:Name="AuthCodeDialog"
            Title="两步验证"
            CloseButtonClick="AuthCodeDialog_CloseButtonClick"
            CloseButtonText="取消"
            DefaultButton="Primary"
            PrimaryButtonClick="AuthCodeDialog_PrimaryButtonClick"
            PrimaryButtonText="验证">
            <StackPanel Spacing="12">
                <TextBlock Margin="0,0,0,12" TextWrapping="Wrap">
                    您的账户已启用两步验证，请输入发送到您信任设备上的6位验证码。<LineBreak />
                    若未收到验证码，请打开<Hyperlink Click="OpenAppleAccountLink">
                        此链接
                    </Hyperlink>
                    ，输入账户与密码以收取验证码。</TextBlock>
                <TextBox
                    x:Name="CodeBox"
                    MinWidth="200"
                    Header="验证码"
                    InputScope="Number"
                    KeyUp="CodeBox_KeyUp"
                    MaxLength="6"
                    PlaceholderText="请输入6位验证码"
                    TextChanged="CodeBox_TextChanged" />
                <TextBlock
                    x:Name="CodeErrorText"
                    Foreground="Red"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
