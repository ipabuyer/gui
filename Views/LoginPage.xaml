<Page
    x:Class="IPAbuyer.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24,16,24,24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="860" HorizontalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="34" FontWeight="Bold" Text="登录" />
                    <TextBlock FontSize="15" Text="输入您的 Apple ID、密码和加密密钥后登录。" />
                    <TextBlock
                        Foreground="Gray"
                        Text="如需修改加密密钥，请先退出登录并重新登录。"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="Gray"
                        Text="提示：新创建的 Apple 账号需要先在苹果设备 App Store 完成一次购买后，才可正常购买与下载。"
                        TextWrapping="WrapWholeWords" />

                    <Border
                        Padding="18"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="电子邮箱地址" />
                            <TextBox
                                x:Name="EmailComboBox"
                                Grid.Row="0"
                                Grid.Column="1"
                                MinWidth="300"
                                MinHeight="36"
                                InputScope="EmailSmtpAddress"
                                IsSpellCheckEnabled="False"
                                KeyUp="Input_KeyUp"
                                PlaceholderText="example@icloud.com" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="密码" />
                            <PasswordBox
                                x:Name="PasswordBox"
                                Grid.Row="1"
                                Grid.Column="1"
                                MinWidth="300"
                                MinHeight="36"
                                KeyUp="Input_KeyUp"
                                PlaceholderText="请输入密码" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="加密密钥" />
                            <PasswordBox
                                x:Name="PassphraseBox"
                                Grid.Row="2"
                                Grid.Column="1"
                                MinWidth="300"
                                MinHeight="36"
                                KeyUp="Input_KeyUp"
                                PasswordRevealMode="Peek"
                                PlaceholderText="用于 ipatool keychain-passphrase" />
                        </Grid>
                    </Border>

                    <Button
                        x:Name="NextButton"
                        MinWidth="140"
                        HorizontalAlignment="Left"
                        Click="NextButton_Click"
                        Content="登录" />

                    <TextBlock
                        x:Name="ResultText"
                        Foreground="Gray"
                        TextWrapping="Wrap" />

                    <ContentDialog
                        x:Name="WarningDialog"
                        Title="警告"
                        CloseButtonText="确认"
                        DefaultButton="Primary" />

                    <ContentDialog
                        x:Name="AuthCodeDialog"
                        Title="两步验证"
                        CloseButtonClick="AuthCodeDialog_CloseButtonClick"
                        CloseButtonText="取消"
                        DefaultButton="Primary"
                        PrimaryButtonClick="AuthCodeDialog_PrimaryButtonClick"
                        PrimaryButtonText="验证">
                        <StackPanel Spacing="12">
                            <TextBlock Margin="0,0,0,12" TextWrapping="Wrap">
                                您的账户已启用两步验证，请输入发送到您信任设备上的 6 位验证码。<LineBreak />
                                若未收到验证码，请打开<Hyperlink Click="OpenAppleAccountLink">此链接</Hyperlink>
                                ，输入账户与密码以收取验证码。
                            </TextBlock>
                            <TextBox
                                x:Name="CodeBox"
                                MinWidth="200"
                                Header="验证码"
                                InputScope="Number"
                                KeyUp="CodeBox_KeyUp"
                                MaxLength="6"
                                PlaceholderText="请输入 6 位验证码"
                                TextChanged="CodeBox_TextChanged" />
                            <TextBlock
                                x:Name="CodeErrorText"
                                Foreground="Red"
                                TextWrapping="Wrap"
                                Visibility="Collapsed" />
                        </StackPanel>
                    </ContentDialog>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
