<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="IPAbuyer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IPAbuyer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <x:Double x:Key="StandardControlHeight">36</x:Double>

            <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="MinHeight" Value="{StaticResource StandardControlHeight}" />
            </Style>

            <Style TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
                <Setter Property="MinHeight" Value="{StaticResource StandardControlHeight}" />
            </Style>

            <Style TargetType="PasswordBox" BasedOn="{StaticResource DefaultPasswordBoxStyle}">
                <Setter Property="MinHeight" Value="{StaticResource StandardControlHeight}" />
            </Style>

            <Style TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
                <Setter Property="MinHeight" Value="{StaticResource StandardControlHeight}" />
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Microsoft YaHei UI, Microsoft YaHei, Segoe UI" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
